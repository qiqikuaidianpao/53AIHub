HUB_VERSION=v0.1.0
HUB_SERVER=prod
DEBUG=true
PORT=9001
SQL_DSN=username:password@tcp(localhost:3306)/53ai_hub?charset=utf8mb4&parseTime=True&loc=UTC
REDIS_CONN=redis://:password@localhost:6379/0
MAX_UPLOAD_FILE_SIZE=15MB

# 文档上传配置
DOCUMENT_SINGLE_FILE_MAX_SIZE=500MB
DOCUMENT_UPLOAD_MAX_CONCURRENT=5
DOCUMENT_UPLOAD_CHUNK_SIZE=5MB
# oss
#STORAGE=aliyun_oss
ALIYUN_OSS_BUCKET_NAME=your_bucket_name
ALIYUN_OSS_ENDPOINT=oss-cn-region.aliyuncs.com
ALIYUN_OSS_ACCESS_KEY_ID=your_access_key_id
ALIYUN_OSS_ACCESS_KEY_SECRET=your_access_key_secret
#BASE_PATH=agent_hub_test/static/uploads

# 可选值: NONE, ERROR, WARN, INFO, DEBUG
# NONE: 不输出任何日志
# ERROR: 只输出错误和致命错误日志
# WARN: 输出警告、错误和致命错误日志
# INFO: 输出信息、警告、错误和致命错误日志（默认）
# DEBUG: 输出所有日志
LOG_LEVEL=INFO
# 单机日志检索 UI 的全局鉴权 token（可选，支持多租户 SaaS 统一查看）
FILE_LOG_VIEWER_ACCESS_TOKEN=

WEWORK_SUITE_ID=

# SMS Configuration (短信配置)
SMS_ENABLED=false
SMS_PROVIDER=253chuanglan
SMS_ACCOUNT=
SMS_PASSWORD=
SMS_SIGN_NAME=博思协创
SMS_CODE_LENGTH=4
SMS_EXPIRY_TIME=15

# SMTP Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your_username
SMTP_PASSWORD=your_password
SMTP_FROM=noreply@yourdomain.com

VECTOR_DB_TYPE=qdrant
VECTOR_DB_URL=http://localhost:6333
VECTOR_DB_API_KEY=API_KEY

# 数据库连接池配置
DB_MAX_OPEN_CONNS=100
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME_SECONDS=3600
DB_CONN_MAX_IDLE_TIME_SECONDS=600


# saas, local
DEPLOYMENT_MODE=

ELASTICSEARCH_ADDRESSES=http://localhost:9200

# Elasticsearch 用户名密码（可选）
LASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_DISABLED=false

DINGTALK_SUITE_ID=

# 前端传输流是否压缩
SSE_STREAM_MODE=compact

# 沙盒服务地址
# SANDBOX_SERVICE_URL="http://localhost:10801"
#
# 沙盒运行时开关（与部署开关分离）:
# - all: 默认，所有会话可用 sandbox 工具
# - off: 禁用 sandbox 工具，run_shell/read_file/write_file/list_files/code-interpreter 将 fail-closed
# - non-main: 预留模式（当前等价于 all）
SANDBOX_MODE=all
#
# 预留给后续 run scope / snapshot / gating 的基础契约参数
SANDBOX_SCOPE=session
SANDBOX_WORKSPACE_ACCESS=rw

# 走新加的 Docker workspace runtime，去掉则走原来的SANDBOX_SERVICE_URL
SANDBOX_RUNTIME_PROVIDER=docker
SANDBOX_RUNTIME_IMAGE=53aihub-sandbox:latest
# 沙盒文件对应宿主机上的目录
SANDBOX_RUNTIME_WORKSPACE_ROOT=/tmp/53aihub-sandbox
# 是Docker 容器里的目录
SANDBOX_RUNTIME_CONTAINER_WORKDIR=/workspace
# 沙盒空闲多久自动回收（秒），默认 3600
SANDBOX_RUNTIME_IDLE_CLEANUP_SECONDS=3600
# 最大循环次数，默认15
AGENT_MAX_TURNS=20

# 并发检索设置默认是4、3、3
RAG_MULTI_LIBRARY_SEARCH_MAX_CONCURRENT=4
RAG_COLLECTION_SEARCH_MAX_CONCURRENT=3
RAG_SEARCH_ENGINE_MAX_WORKERS=3