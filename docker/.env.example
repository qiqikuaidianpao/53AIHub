# --- Core application ---
COMPOSE_PROJECT_NAME=53ai-hub
HUB_IMAGE=registry.cn-hangzhou.aliyuncs.com/53ai/53aihub:latest
HUB_SERVER=local
PORT=3000
API_HOST=http://localhost:3000
DEPLOYMENT_MODE=local
DEBUG=false
LOG_LEVEL=info
MIGRATE_DB_ENABLED=true

# --- MySQL ---
MYSQL_IMAGE=mysql:8.0
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=53ai_hub
MYSQL_USER=agent
MYSQL_PASSWORD=agentpassword
SQL_DSN=agent:agentpassword@tcp(mysql:3306)/53ai_hub?charset=utf8mb4&parseTime=True&loc=UTC

# --- Redis ---
REDIS_IMAGE=redis:7.2-bookworm
REDIS_REQUIREPASS=your_redis_password
REDIS_MAXMEMORY=256mb
REDIS_MAXMEMORY_POLICY=allkeys-lru
REDIS_CONN=redis://:your_redis_password@redis:6379/0

# --- Vector database ---
QDRANT_IMAGE=qdrant/qdrant:latest
VECTOR_DB_TYPE=qdrant
VECTOR_DB_URL=http://qdrant:6333
VECTOR_DB_API_KEY=your_qdrant_key

# --- Document conversion ---
DOC_CONVERT_BASE_URL=http://file-service:5022
DOC_CONVERT_API_KEY=
DOC_CONVERT_TIMEOUT=1800
DOC_CONVERT_MAX_FILE_SIZE=100MB
DOC_CONVERT_RETRY_TIMES=3
DOC_CONVERT_POLL_INTERVAL=5

# --- File preview service ---
KK_REDIS_ADDRESS=redis:6379
KK_REDIS_PASSWORD=your_redis_password
KK_BASE_URL=http://localhost:9006
KK_TRUST_HOST=*

# --- File conversion service ---
FILE_SERVICE_DOWNLOAD_TIMEOUT_SEC=1800
FILE_SERVICE_CONVERT_TIMEOUT_SEC=1800
FILE_SERVICE_MYSQL_DSN=agent:agentpassword@tcp(mysql:3306)/53ai_hub?charset=utf8mb4&parseTime=True&loc=UTC
FILE_SERVICE_REDIS_URL=redis://:your_redis_password@redis:6379/1
FILE_SERVICE_APP_PORT=5022

# --- Sandbox ---
SANDBOX_IMAGE=registry.cn-hangzhou.aliyuncs.com/53ai/53ai-sandbox:latest
SANDBOX_SERVICE_URL=http://sandbox:8000
SANDBOX_RUNTIME_PROVIDER=docker
SANDBOX_RUNTIME_IMAGE=53ai-sandbox:latest
SANDBOX_RUNTIME_WORKSPACE_ROOT=/tmp/53ai-sandbox
SANDBOX_RUNTIME_CONTAINER_PREFIX=53ai-sbx-
SANDBOX_RUNTIME_CONTAINER_WORKDIR=/workspace
SANDBOX_RUNTIME_TIMEOUT_SECONDS=300
SANDBOX_RUNTIME_IDLE_CLEANUP_SECONDS=3600
SANDBOX_RUNTIME_NETWORK_ENABLED=true
SANDBOX_RUNTIME_READ_ONLY_ROOT=false

