{
  "name": "@km/mobile",
  "version": "0.0.1",
  "private": true,
  "description": "KM 移动端 React (Expo) 应用，可编译为 iOS/Android App",
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build": "expo export",
    "type-check": "tsc --noEmit --skipLibCheck"
  },
  "dependencies": {
    "@babel/runtime": "^7.25.0",
    "@expo/metro-runtime": "~4.0.1",
    "@km/shared-public": "workspace:*",
    "@km/shared-utils": "workspace:*",
    "expo": "~52.0.0",
    "expo-constants": "~17.0.0",
    "expo-linking": "~7.0.0",
    "expo-router": "~4.0.0",
    "expo-status-bar": "~2.0.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.5",
    "react-native-css-interop": "^0.2.2",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "15.8.0",
    "react-native-web": "~0.19.13",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~18.3.12",
    "babel-preset-expo": "~12.0.0",
    "nativewind": "^4.1.23",
    "react-native-svg-transformer": "^1.5.0",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.3.0"
  }
}
