    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^18.14.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.13",
    "cross-env": "^7.0.3",
    "jsdom": "^26.1.0",
    "postcss": "^8.4.21",
    "tailwindcss": "^3.2.7",
    "typescript": "~5.6.0",
    "unplugin-auto-import": "^0.17.0",
    "vite": "^5.4.10",
    "vite-plugin-svg-icons": "^2.0.1",
    "vitest": "^2.1.0"
  }
