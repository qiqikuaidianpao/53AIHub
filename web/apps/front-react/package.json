  "description": "53aikm React",
  "author": "53aihub",
  "homepage": "https://53ai.com/",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:rc": "vite --mode rc",
    "dev:prod": "vite --mode production",
    "dev:local": "cross-env VITE_PLATFORM=op-local vite",
    "dev:mock": "vite --mode mock",
    "build": "vite build",
    "build:local": "cross-env VITE_PLATFORM=op-local vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@ant-design/icons": "^5.5.0",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "6.6.0",
    "@codemirror/view": "6.40.0",
    "@km/hub-ui-x-react": "workspace:*",
    "@km/shared-business": "workspace:*",
    "@km/shared-components-react": "workspace:*",
    "@km/shared-utils": "workspace:*",
    "@uiw/react-codemirror": "^4.25.8",
    "antd": "^6.3.4",
    "axios": "^1.3.4",
    "i18next": "^23.16.0",
    "i18next-browser-languagedetector": "^8.0.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.1.0",
    "react-router-dom": "^6.28.0",
    "zustand": "^5.0.0"
