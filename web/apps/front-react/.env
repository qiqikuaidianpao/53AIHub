# Compiler Environment Platform
# 是不是km版本  km|web
VITE_PLATFORM=km
# 是否包含 KM 功能（与 #ifdef KM 对应，通过 $vars.includeKm 判断）
VITE_INCLUDE_KM=true
# 商业私有化版本
VITE_PRIVATE_PREM=false
VITE_BASE_PATH=/

# Dev
VITE_GLOB_AUTH_KEY=auth_key
# 企业微信套件id
VITE_GLOB_SUITEID=suiteid
# 微信登录公众号id
VITE_GLOB_OFFICIALID=officialid
# 后端地址， 如果是域名地址，为空
VITE_GLOB_API_HOST=
# 后台地址
VITE_GLOB_ADMIN_URL=/console
# kkfileview地址
VITE_GLOB_KKFILEVIEW_URL=
