{
  "name": "@km/shared-business",
  "version": "0.0.1",
  "description": "Shared business modules for KM apps",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./agent-create": {
      "import": "./dist/agent-create/index.js",
      "types": "./dist/agent-create/index.d.ts"
    },
    "./chat": {
      "import": "./dist/chat/index.js",
      "types": "./dist/chat/index.d.ts"
    },
    "./auth": {
      "import": "./dist/auth/index.js",
      "types": "./dist/auth/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "react-router-dom": ">=6.0.0",
    "antd": ">=6.0.0",
    "@ant-design/icons": ">=5.0.0",
    "zustand": ">=4.0.0",
    "i18next": ">=22.0.0",
    "react-i18next": ">=12.0.0",
    "@dnd-kit/core": ">=6.0.0",
    "@dnd-kit/sortable": ">=8.0.0",
    "@dnd-kit/utilities": ">=3.0.0"
  },
  "dependencies": {
    "@km/hub-ui-x-react": "workspace:*",
    "@km/shared-components-react": "workspace:*",
    "@km/shared-utils": "workspace:*",
    "antd": "^6.0.0"
  },
  "devDependencies": {
    "@ant-design/icons": "^5.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "tsup": "^8.0.0",
    "typescript": "~5.6.0"
  }
}
