{
  "name": "km-monorepo",
  "version": "0.3.9",
  "private": true,
  "description": "53AI KM Monorepo - front, console & mobile",
  "author": "53aihub",
  "scripts": {
    "dev:front": "pnpm --filter @km/front-react dev",
    "dev:console": "pnpm --filter @km/console-react dev",
    "build:front": "pnpm --filter @km/front-react build",
    "build:console": "pnpm --filter @km/console-react build",
    "dev:mobile": "pnpm --filter @km/mobile dev",
    "dev:mobile:web": "pnpm --filter @km/mobile web",
    "build:mobile": "pnpm --filter @km/mobile build",
    "build:shared": "pnpm --filter @km/shared-utils --filter @km/shared-types --filter @km/shared-components-react --filter @km/shared-business --filter @km/hub-ui-x-react run build",
    "dev": "turbo run dev",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean",
    "clean:vite": "rimraf apps/front/node_modules/.vite apps/console/node_modules/.vite",
    "clean:modules": "rimraf node_modules apps/*/node_modules packages/*/node_modules",
    "clean:report": "node scripts/clean-report.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@babel/runtime": "^7.25.0",
    "@biomejs/biome": "^2.2.0",
    "@commitlint/cli": "^17.4.4",
    "@commitlint/config-conventional": "^17.4.4",
    "husky": "^9.1.7",
    "knip": "^6.12.0",
    "lint-staged": "^16.1.2",
    "rimraf": "^5.0.5",
    "turbo": "^2.3.0"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "overrides": {
      "react": "^18.3.1",
      "react-dom": "^18.3.1",
      "@codemirror/state": "6.6.0",
      "@codemirror/view": "6.40.0",
      "@element-plus/icons-vue": "^2.3.2",
      "@vue/reactivity": "^3.4.24",
      "@vueuse/core": "^9.13.0",
      "axios": "^1.3.4",
      "buffer": "^6.0.3",
      "cross-env": "^7.0.3",
      "element-plus": "^2.9.5",
      "hub-ui-x": "^0.0.50",
      "pinia": "^2.3.1",
      "vditor": "^3.11.2",
      "vue": "~3.5.11",
      "vue-codemirror": "^6.1.1",
      "vue-cropper": "^1.0.9",
      "vue-i18n": "^9.2.2",
      "vue-router": "^4.2.5",
      "@types/node": "^18.14.6",
      "@vitejs/plugin-vue": "^4.4.0",
      "autoprefixer": "^10.4.13",
      "npm-run-all": "^4.1.5",
      "postcss": "^8.4.21",
      "postcss-scss": "^4.0.9",
      "rollup-plugin-visualizer": "^5.11.0",
      "sass": "^1.62.1",
      "tailwindcss": "^3.2.7",
      "typescript": "~4.9.5",
      "unplugin-auto-import": "^0.15.3",
      "unplugin-icons": "^0.18.1",
      "unplugin-vue-components": "^0.24.1",
      "vite": "^4.4.11",
      "vite-plugin-pwa": "^0.14.4",
      "vite-plugin-svg-icons": "^2.0.1",
      "vite-plugin-top-level-await": "^1.4.4",
      "vite-plugin-wasm": "^3.3.0",
      "vue-tsc": "^1.8.16"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
